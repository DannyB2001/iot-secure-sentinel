# NextAuth v4 secret. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-me-with-32-bytes-of-randomness

# Public URL the frontend uses to reach NextAuth in production.
# In dev, NextAuth derives this from the request; in prod it must be set.
NEXTAUTH_URL=http://localhost:3000

# Optional persistent MongoDB. Leave unset for local in-memory MongoDB.
# For Raspberry Pi / hardware demos, prefer a real MongoDB so data survives restarts.
# MONGODB_URI=mongodb://127.0.0.1:27017/iris
MONGODB_DB=iris

# Default seed admin (created on first DB boot if no users exist)
SEED_ADMIN_EMAIL=admin@iris.local
SEED_ADMIN_PASSWORD=admin123

# Default device API token used by scripts/mock-device.ts (also seeded on first boot)
SEED_DEVICE_NAME=mock-gateway-01
SEED_DEVICE_TOKEN=mock-token-please-rotate
