# Auth.js v5 secret. Generate with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-32-bytes-of-randomness

# Default seed admin (created on first DB boot if no users exist)
SEED_ADMIN_EMAIL=admin@iris.local
SEED_ADMIN_PASSWORD=admin123

# Default device API token used by scripts/mock-device.ts (also seeded on first boot)
SEED_DEVICE_NAME=mock-gateway-01
SEED_DEVICE_TOKEN=mock-token-please-rotate
